{
  "functions": {
    "api/website/analyse.js": {
      "maxDuration": 300
    },
    "api/cron/cleanup-media.js": {
      "maxDuration": 300
    },
    "api/*.js": {
      "maxDuration": 60
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/publish-due",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/cleanup-media",
      "schedule": "15 4 * * *"
    }
  ]
}
